GROQ_API_KEY="your_groq_api_key_here"

# Tavily Search API (required for web search tool)
# Free plan: 1,000 requests/month — sign up at https://tavily.com
TAVILY_API_KEY="your_tavily_api_key_here"
PORT=3001
# Comma-separated list of allowed frontend origins (leave empty to allow all)
ALLOWED_ORIGINS="https://your-app.vercel.app"

# Google OAuth (required for long-term memory feature)
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# JWT signing secret — use a long random string (e.g. openssl rand -base64 32)
JWT_SECRET="your_jwt_secret_here"

# Frontend URL — used for OAuth redirect after login
# Local dev: http://localhost:5173
# Production: https://your-app.vercel.app
FRONTEND_URL="http://localhost:5173"

# Backend URL — used to construct the OAuth callback URL
# Local dev: http://localhost:3001
# Production: https://your-backend.onrender.com
BACKEND_URL="http://localhost:3001"

# Firebase (required for long-term memory persistence)
# Create at: https://console.firebase.google.com → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com"
# Paste the private key with literal \n (Render/Vercel env vars store it this way)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

TAVILY_API_KEY=""